{
    "headers": [
        {
            "source": "/(.*)\\.html",
            "headers": [
                { "key": "Content-Type", "value": "text/html; charset=utf-8" },
                { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://flagcdn.com; connect-src 'self';" }
            ]
        },
        {
            "source": "/(.*)\\.js",
            "headers": [
                { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
            ]
        }
    ],
    "rewrites": [
        { "source": "/in", "destination": "/index.html" },
        { "source": "/us", "destination": "/index.html" },
        { "source": "/privacy", "destination": "/legal.html" },
        { "source": "/terms", "destination": "/legal.html" },
        { "source": "/disclaimer", "destination": "/legal.html" },
        { "source": "/support-us", "destination": "/support-us.html" },
        { "source": "/:country([a-zA-Z]{2})", "destination": "/index.html" }
    ],
    "redirects": [
        { "source": "/mastermanikant/github", "destination": "https://github.com/MasterManikant", "permanent": true },
        { "source": "/mastermanikant/x", "destination": "https://x.com/MasterManikant", "permanent": true },
        { "source": "/mastermanikant/linkedin", "destination": "https://linkedin.com/in/mastermanikant", "permanent": true },
        { "source": "/mastermanikant/youtube", "destination": "https://youtube.com/@MasterManikant", "permanent": true },
        { "source": "/mastermanikant/instagram", "destination": "https://instagram.com/mastermanikant", "permanent": true },
        { "source": "/mastermanikant/facebook", "destination": "https://facebook.com/mastermanikant", "permanent": true },
        { "source": "/x", "destination": "https://x.com/iamfrankpass", "permanent": true },
        { "source": "/youtube", "destination": "https://youtube.com/@iamfrankpass", "permanent": true },
        { "source": "/instagram", "destination": "https://instagram.com/iamfrankpass", "permanent": true },
        { "source": "/whatsapp", "destination": "https://whatsapp.com/channel/0029VbBvVfqLNSa2At2Shf2z", "permanent": true },
        { "source": "/facebook", "destination": "https://facebook.com/iamfrankpass", "permanent": true },
