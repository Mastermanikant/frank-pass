{
    "cleanUrls": true,
    "headers":  [
                    {
                        "source":  "/(.*)\\.html",
                        "headers":  [
                                        {
                                            "key":  "Content-Type",
                                            "value":  "text/html; charset=utf-8"
                                        },
                                        {
                                            "key":  "Content-Security-Policy",
                                            "value":  "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://flagcdn.com; connect-src 'self' https://unpkg.com;"
                                        }
                                    ]
                    },
                    {
                        "source":  "/(.*)\\.js",
                        "headers":  [
                                        {
                                            "key":  "Content-Type",
                                            "value":  "application/javascript; charset=utf-8"
                                        }
                                    ]
                    }
                ],
    "rewrites":  [{"source": "/privacy","destination": "/legal.html"},{"source": "/terms","destination": "/legal.html"},{"source": "/disclaimer","destination": "/legal.html"},{"source": "/:country([a-zA-Z]{2})","destination": "/index.html"},{"source": "/:country([a-zA-Z]{2})/","destination": "/index.html"}],
    "redirects":  [
